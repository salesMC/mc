<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

  <%- include('partials/header') %>

  <main class="relative overflow-hidden min-h-[75vh] flex items-center">
    <div class="glow-orange" style="top: 10%; left: -100px;"></div>
    <div class="glow-cyan" style="bottom: 10%; right: -100px;"></div>

    <div class="relative max-w-2xl mx-auto px-6 lg:px-8 text-center py-24">
      <div class="text-[11rem] md:text-[13rem] font-bold text-white leading-none tracking-tight"
           style="background: linear-gradient(180deg, rgba(255,106,61,0.9), rgba(34,211,238,0.3)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
        404
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-white mt-4 tracking-tight">Page not found</h1>
      <p class="mt-5 text-lg text-dim">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/contact" class="btn btn-ghost">Contact Us</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
