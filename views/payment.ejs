<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Request a Quote | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    /* Prevent content being hidden under sticky bottom nav on mobile */
    html { scroll-padding-bottom: 80px; }

    /* ── Base inputs ── */
    .input-dark {
      width: 100%;
      padding: 0.875rem 1rem;
      background: #161B22;
      border: 1px solid #1F2937;
      border-radius: 0.5rem;
      color: white;
      transition: border-color 0.2s, box-shadow 0.2s;
      font-size: 1rem;        /* prevents iOS zoom on focus (must be ≥16px) */
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }
    .input-dark::placeholder { color: #8B949E; }
    .input-dark:focus {
      border-color: #FF6A3D;
      box-shadow: 0 0 0 3px rgba(255,106,61,0.15);
    }
    .input-dark.error {
      border-color: #ef4444 !important;
      box-shadow: 0 0 0 3px rgba(239,68,68,0.2) !important;
    }

    /* ── Labels / errors ── */
    .label-dark {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: #8B949E;
      margin-bottom: 0.4rem;
    }
    .error-msg {
      color: #ef4444;
      font-size: 0.78rem;
      margin-top: 4px;
      min-height: 18px;
    }
    .vin-result { color: #BEF264; font-weight: 500; }
    .vin-error  { color: #F87171; }

    /* ── Sidebar step pills ── */
    .step-active {
      border-color: #FF6A3D;
      background: rgba(255,106,61,0.12);
      color: white;
    }

    /* ── Transport toggle ── */
    .btn-transport { transition: all 0.2s; }
    .btn-transport.active {
      background: #FF6A3D;
      color: white;
      border-color: #FF6A3D;
    }

    /* ── Photo upload zone ── */
    .upload-zone {
      border: 2px dashed #374151;
      background: #161B22;
      border-radius: 12px;
      transition: border-color 0.2s, background 0.2s;
    }
    .upload-zone:hover { border-color: #FF6A3D; background: #1F2937; }

    /* ── Vehicle tabs ── */
    .vehicle-tab {
      padding: 0.45rem 0.9rem;
      border-radius: 0.5rem;
      font-size: 0.82rem;
      font-weight: 600;
      border: 1px solid #1F2937;
      color: #8B949E;
      background: #161B22;
      cursor: pointer;
      transition: border-color 0.18s, color 0.18s, background 0.18s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .vehicle-tab.active {
      border-color: #FF6A3D;
      color: white;
      background: rgba(255,106,61,0.12);
    }
    .vehicle-tab:hover:not(.active) { border-color: #374151; color: #C9D1D9; }

    .add-vehicle-tab {
      padding: 0.45rem 0.85rem;
      border-radius: 0.5rem;
      font-size: 0.82rem;
      font-weight: 600;
      border: 1px dashed rgba(255,106,61,0.4);
      color: #FF6A3D;
      background: rgba(255,106,61,0.04);
      cursor: pointer;
      transition: all 0.18s;
      flex-shrink: 0;
    }
    .add-vehicle-tab:hover { border-color: #FF6A3D; background: rgba(255,106,61,0.1); }

    .remove-vtab {
      margin-left: 0.35rem;
      opacity: 0.5;
      transition: opacity 0.15s;
    }
    .remove-vtab:hover { opacity: 1; color: #ef4444; }

    /* ══════════════════════════════════════════
       MOBILE LAYOUT  (≤ 1023 px)
    ══════════════════════════════════════════ */
    @media (max-width: 1023px) {

      /* Sidebar becomes a sticky top bar (not a side column) */
      .sidebar-sticky {
        position: sticky !important;
        top: 0;
        z-index: 30;
        background: #0D1117;
        border-bottom: 1px solid #1F2937;
        border-radius: 0 !important;
        padding: 0.6rem 1rem !important;
        overflow: hidden;
      }
      .sidebar-title { display: none !important; }

      /* Steps scroll horizontally */
      #steps {
        display: flex !important;
        flex-direction: row !important;
        gap: 0.25rem !important;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        padding-bottom: 0 !important;
        margin: 0 !important;
        touch-action: pan-x;
      }
      #steps::-webkit-scrollbar { display: none; }

      .step-item {
        padding: 0.4rem 0.75rem !important;
        font-size: 0.75rem !important;
        white-space: nowrap;
        border-radius: 999px !important;
        flex-shrink: 0;
      }

      /* Compact total row */
      .sidebar-total {
        display: flex !important;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.5rem !important;
        padding-top: 0.5rem !important;
        border-top: 1px solid #1F2937;
      }
      #totalPriceSidebar { font-size: 1.5rem !important; margin-top: 0 !important; }
      #vehicleCountSidebar { font-size: 0.7rem !important; }
    }

    /* ══════════════════════════════════════════
       SMALL PHONE  (≤ 639 px)
    ══════════════════════════════════════════ */
    @media (max-width: 639px) {

      .tile { padding: 1rem !important; }

      /* Larger tap targets */
      .input-dark { padding: 0.9rem 1rem; font-size: 1rem; }

      /* Vehicle tabs — horizontal scroll */
      #vehicleTabs {
        flex-wrap: nowrap !important;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        padding-bottom: 2px;
        touch-action: pan-x;
      }
      #vehicleTabs::-webkit-scrollbar { display: none; }

      /* Nav buttons full width, stacked */
      .nav-btn-row { flex-direction: column !important; gap: 0.5rem; }
      .nav-btn-row button { width: 100% !important; justify-content: center; }

      /* Route date grid single column */
      .route-date-grid { grid-template-columns: 1fr !important; }

      /* Transport buttons stacked */
      .transport-btns { flex-direction: column !important; }
      .transport-btns button { width: 100% !important; }

      /* Stripe expiry / cvc 50/50 */
      .stripe-expiry-cvc { grid-template-columns: 1fr 1fr !important; }

      /* Vehicle form year/make/model: single column on tiny screens */
      .vehicle-ymm-grid { grid-template-columns: 1fr !important; }

      /* Step number hidden on very small screens */
      .step-item .step-num { display: none; }
    }

    /* ══════════════════════════════════════════
       ULTRA SMALL  (≤ 380 px)
    ══════════════════════════════════════════ */
    @media (max-width: 380px) {
      .step-item { padding: 0.35rem 0.6rem !important; font-size: 0.7rem !important; }
    }

    /* Safe area padding for notched iPhones */
    @supports (padding-bottom: env(safe-area-inset-bottom)) {
      .nav-btn-row {
        padding-bottom: env(safe-area-inset-bottom);
      }
    }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <main class="relative py-6 sm:py-12 bg-deep min-h-screen" style="overflow-x:clip;">
    <div class="glow-orange" style="top: -100px; left: -120px;"></div>
    <div class="glow-cyan" style="bottom: -80px; right: -100px;"></div>

    <div class="relative max-w-7xl mx-auto px-3 sm:px-5 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-4 lg:gap-8">

        <!-- ─── Sidebar ─── -->
        <div class="lg:col-span-4 xl:col-span-3">
          <div class="tile p-4 lg:p-8 lg:sticky lg:top-24 sidebar-sticky">
            <h2 class="text-2xl font-bold text-white mb-6 sidebar-title">Request a Quote</h2>

            <!-- Steps nav -->
            <div id="steps" class="space-y-2">
              <div onclick="goToStep(0)" class="step-item flex items-center gap-2 cursor-pointer p-3 rounded-xl step-active text-sm" data-step="0">
                <span class="step-num font-mono text-orange-400">1</span> Contact
              </div>
              <div onclick="goToStep(1)" class="step-item flex items-center gap-2 cursor-pointer p-3 rounded-xl text-sm" data-step="1">
                <span class="step-num font-mono text-orange-400">2</span> Vehicles
              </div>
              <div onclick="goToStep(2)" class="step-item flex items-center gap-2 cursor-pointer p-3 rounded-xl text-sm" data-step="2">
                <span class="step-num font-mono text-orange-400">3</span> Route
              </div>
              <div onclick="goToStep(3)" class="step-item flex items-center gap-2 cursor-pointer p-3 rounded-xl text-sm" data-step="3">
                <span class="step-num font-mono text-orange-400">4</span> Summary
              </div>
              <div onclick="goToStep(4)" class="step-item flex items-center gap-2 cursor-pointer p-3 rounded-xl text-sm" data-step="4">
                <span class="step-num font-mono text-orange-400">5</span> Payment
              </div>
            </div>

            <!-- Total -->
            <div class="mt-8 pt-6 border-t border-[var(--line)] sidebar-total">
              <div>
                <div class="text-xs text-muted">Estimated Total</div>
                <div id="totalPriceSidebar" class="text-3xl lg:text-5xl font-bold text-[var(--orange)] mt-0.5">$0</div>
                <div id="vehicleCountSidebar" class="text-xs text-muted mt-0.5"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- ─── Main Content ─── -->
        <div class="lg:col-span-8 xl:col-span-9">
          <!-- Step content card -->
          <div class="tile p-5 sm:p-8 md:p-10 lg:p-12 min-h-[520px]" id="stepContent"></div>

          <!-- Nav buttons — sticky bottom on mobile -->
          <div class="flex flex-col sm:flex-row justify-between gap-3 mt-5 sm:mt-8
                      sticky bottom-0 sm:static
                      z-20
                      bg-[#0D1117] sm:bg-transparent
                      border-t border-[var(--line)] sm:border-none
                      px-3 sm:px-0 py-3 sm:py-0
                      nav-btn-row">
            <button onclick="prevStep()" id="prevBtn"
                    class="btn btn-ghost px-6 py-4 hidden">
              ← Previous
            </button>
            <button onclick="nextStep()" id="nextBtn"
                    class="btn btn-primary px-8 py-4 font-semibold text-base">
              Next →
            </button>
          </div>
        </div>

      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // ==================== CONFIG ====================
    let calculatorConfig = {
      baseFee: 120,
      tiers: [
        { max: 30,       rate: 3.00 },
        { max: 70,       rate: 2.20 },
        { max: 110,      rate: 1.80 },
        { max: 160,      rate: 1.50 },
        { max: Infinity, rate: 1.30 }
      ],
      multipliers: {
        'sedan': 1.00, 'mid-suv': 1.10, 'full-suv': 1.20,
        'pickup': 1.15, 'cargo-van': 1.25, 'passenger-van': 1.25, 'mini-van': 1.00, 'other': 1.20
      },
      addons: { inoperable: 75, modified: 100, urgent: 100 }
    };
    const savedCfg = localStorage.getItem('calculatorConfig');
    if (savedCfg) try { calculatorConfig = JSON.parse(savedCfg); } catch(_) {}

    let currentStep = 0;
    let fromAutocomplete, toAutocomplete, distanceService;
    let activeVehicleTab = 0;
    let appliedPromo = null; // { code, discount, type }

    let formData = {
      contact: { fullName: '', email: '', phone: '' },
      vehicles: [freshVehicle()],
      location: { pickup: '', delivery: '' },
      pickupDate: '', mustDeliverBy: '',
      transportType: 'open',
      total: 0
    };

    function freshVehicle() {
      return {
        year: '', make: '', model: '', vin: '',
        type: 'sedan', condition: 'operable',
        modified: false, urgent: false,
        runsAndDrives: true, hasKeys: true, photos: []
      };
    }

    // ==================== VIN DECODER ====================
    async function decodeVIN(vin) {
      try {
        const res  = await fetch(`https://vpic.nhtsa.dot.gov/api/vehicles/decodevinvalues/${vin}?format=json`);
        const data = await res.json();
        return data.Results?.[0] ?? null;
      } catch { return null; }
    }

    // ==================== GOOGLE MAPS ====================
    function initGoogleAutocomplete() {
      const opts = { types: ['address'], componentRestrictions: { country: 'us' } };
      fromAutocomplete = new google.maps.places.Autocomplete(document.getElementById('pickupAddr'),   opts);
      toAutocomplete   = new google.maps.places.Autocomplete(document.getElementById('deliveryAddr'), opts);
      fromAutocomplete.addListener('place_changed', calculateDistance);
      toAutocomplete.addListener('place_changed',   calculateDistance);
    }

    function calculateDistance() {
      const pickup   = document.getElementById('pickupAddr')?.value.trim();
      const delivery = document.getElementById('deliveryAddr')?.value.trim();
      if (!pickup || !delivery || !distanceService) return;
      distanceService.getDistanceMatrix(
        { origins: [pickup], destinations: [delivery],
          travelMode: google.maps.TravelMode.DRIVING,
          unitSystem: google.maps.UnitSystem.IMPERIAL },
        (response, status) => {
          if (status === 'OK' && response.rows[0].elements[0].status === 'OK') {
            const miles = Math.round(response.rows[0].elements[0].distance.value * 0.000621371);
            const distEl = document.getElementById('distance');
            if (distEl) distEl.value = miles;
            calculateAndUpdateTotal();
          }
        }
      );
    }

    // ==================== PRICE CALCULATION ====================
    function calcVehiclePrice(miles, v) {
      miles = Math.max(0, miles || 0);
      let cpm = calculatorConfig.tiers[calculatorConfig.tiers.length - 1].rate;
      for (const tier of calculatorConfig.tiers) {
        if (miles <= tier.max) { cpm = tier.rate; break; }
      }
      let subtotal = calculatorConfig.baseFee + (cpm * miles);
      if (calculatorConfig.multipliers[v.type]) subtotal *= calculatorConfig.multipliers[v.type];
      if (v.condition === 'inoperable') subtotal += calculatorConfig.addons.inoperable;
      if (v.modified) subtotal += calculatorConfig.addons.modified;
      if (v.urgent)   subtotal += calculatorConfig.addons.urgent;
      return Math.round(subtotal);
    }

    function calculateAndUpdateTotal() {
      const miles = Math.max(0, parseFloat(document.getElementById('distance')?.value) || 0);
      let grand = 0;
      formData.vehicles.forEach(v => { grand += calcVehiclePrice(miles, v); });

      // Apply promo discount
      let discountAmount = 0;
      if (appliedPromo) {
        if (appliedPromo.type === 'percent') {
          discountAmount = Math.round(grand * appliedPromo.discount / 100);
        } else {
          discountAmount = Math.min(Math.round(appliedPromo.discount * 100) / 100 * 100, grand * 100) / 100;
          discountAmount = Math.min(appliedPromo.discount, grand);
        }
      }
      formData.total = Math.max(0, grand - discountAmount);

      const sidebarTotal = document.getElementById('totalPriceSidebar');
      const sidebarCount = document.getElementById('vehicleCountSidebar');
      if (sidebarTotal) sidebarTotal.textContent = '$' + formData.total.toLocaleString();
      if (sidebarCount) sidebarCount.textContent = formData.vehicles.length > 1 ? formData.vehicles.length + ' vehicles' : '';

      const ft2 = document.getElementById('finalTotal2');
      if (ft2) ft2.textContent = '$' + formData.total.toLocaleString();

      // Update discount line in summary if visible
      updateDiscountLine(grand, discountAmount);
    }

    function updateDiscountLine(subtotal, discountAmount) {
      const discountLine = document.getElementById('promoDiscountLine');
      if (!discountLine) return;
      if (appliedPromo && discountAmount > 0) {
        discountLine.classList.remove('hidden');
        discountLine.innerHTML = `
          <div class="flex justify-between items-center text-lime-400">
            <span><i class="fas fa-tag mr-1"></i> Promo <span class="font-mono font-bold">${appliedPromo.code}</span>
              ${appliedPromo.type === 'percent' ? '(−' + appliedPromo.discount + '%)' : ''}
            </span>
            <span>−$${discountAmount.toLocaleString()}</span>
          </div>`;
      } else {
        discountLine.classList.add('hidden');
      }
    }

    // ==================== PHOTO UPLOAD ====================
    function initPhotoUpload(vehicleIndex) {
      const oldInput = document.getElementById('vehiclePhotos-' + vehicleIndex);
      if (!oldInput) return;
      const input = oldInput.cloneNode(true);
      oldInput.parentNode.replaceChild(input, oldInput);
      const preview = document.getElementById('photoPreview-' + vehicleIndex);

      input.addEventListener('change', () => {
        Array.from(input.files).forEach(file => {
          if (formData.vehicles[vehicleIndex].photos.length >= 8) return alert('Maximum 8 photos allowed');
          if (!file.type.startsWith('image/')) return;
          const reader = new FileReader();
          reader.onload = (e) => {
            formData.vehicles[vehicleIndex].photos.push({ name: file.name, data: e.target.result });
            const div = document.createElement('div');
            div.className = 'relative';
            div.innerHTML = `<img src="${e.target.result}" class="rounded-lg border border-[var(--line)] object-cover h-24 w-full">
              <button class="absolute -top-2 -right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs"
                      onclick="removePhoto(this, ${vehicleIndex})">×</button>`;
            preview.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
        input.value = '';
      });
    }

    window.removePhoto = function(el, vehicleIndex) {
      const preview = document.getElementById('photoPreview-' + vehicleIndex);
      const index   = Array.from(preview.children).indexOf(el.parentElement);
      if (index > -1) formData.vehicles[vehicleIndex].photos.splice(index, 1);
      el.parentElement.remove();
    };

    // ==================== YEAR SELECT ====================
    function createYearSelect(id) {
      const select = document.createElement('select');
      select.id = id;
      select.className = 'input-dark';
      select.required = true;
      const def = document.createElement('option');
      def.value = ''; def.textContent = 'Select year';
      select.appendChild(def);
      for (let y = 2030; y >= 1900; y--) {
        const opt = document.createElement('option');
        opt.value = y; opt.textContent = y;
        select.appendChild(opt);
      }
      return select;
    }

    // ==================== VEHICLE TABS ====================
    function renderVehicleTabs() {
      const container = document.getElementById('vehicleTabs');
      if (!container) return;
      container.innerHTML = '';

      formData.vehicles.forEach((v, i) => {
        const tab = document.createElement('button');
        tab.type = 'button';
        tab.className = 'vehicle-tab' + (i === activeVehicleTab ? ' active' : '');
        tab.innerHTML = `Vehicle ${i + 1}${formData.vehicles.length > 1
          ? ` <span class="remove-vtab" onclick="removeVehicleTab(event,${i})">×</span>` : ''}`;
        tab.addEventListener('click', (e) => {
          if (e.target.classList.contains('remove-vtab')) return;
          saveCurrentVehicleData();
          activeVehicleTab = i;
          renderVehicleTabs();
          renderVehicleForm(i);
        });
        container.appendChild(tab);
      });

      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      addBtn.className = 'add-vehicle-tab';
      addBtn.innerHTML = '<i class="fas fa-plus"></i> Add Vehicle';
      addBtn.onclick = () => {
        saveCurrentVehicleData();
        formData.vehicles.push(freshVehicle());
        activeVehicleTab = formData.vehicles.length - 1;
        renderVehicleTabs();
        renderVehicleForm(activeVehicleTab);
      };
      container.appendChild(addBtn);
    }

    window.removeVehicleTab = function(e, i) {
      e.stopPropagation();
      if (formData.vehicles.length <= 1) return;
      formData.vehicles.splice(i, 1);
      if (activeVehicleTab >= formData.vehicles.length) activeVehicleTab = formData.vehicles.length - 1;
      renderVehicleTabs();
      renderVehicleForm(activeVehicleTab);
      setTimeout(() => {
        initPhotoUpload(activeVehicleTab);
        const yc = document.getElementById('yearContainer-' + activeVehicleTab);
        if (yc && !yc.querySelector('select')) yc.appendChild(createYearSelect('year-' + activeVehicleTab));
        initVehicleVIN(activeVehicleTab);
      }, 60);
    };

    function renderVehicleForm(i) {
      const v = formData.vehicles[i];
      const fc = document.getElementById('vehicleFormContainer');
      if (!fc) return;
      fc.innerHTML = vehicleFormHTML(i, v);

      setTimeout(() => {
        // Year select
        const yc = document.getElementById('yearContainer-' + i);
        yc.innerHTML = '';
        yc.appendChild(createYearSelect('year-' + i));
        const yearSelect = document.getElementById('year-' + i);
        if (v.year) yearSelect.value = v.year;

        initPhotoUpload(i);
        initVehicleVIN(i);

        // Restore field values
        const make  = document.getElementById('make-' + i);
        const model = document.getElementById('model-' + i);
        const vin   = document.getElementById('vin-' + i);
        if (make)  make.value  = v.make  || '';
        if (model) model.value = v.model || '';
        if (vin)   vin.value   = v.vin   || '';

        document.getElementById('vehicleType-' + i).value = v.type || 'sedan';
        const condEl = document.querySelector(`input[name="condition-${i}"][value="${v.condition || 'operable'}"]`);
        if (condEl) condEl.checked = true;
        document.getElementById('modifiedCheck-' + i).checked = v.modified || false;
        document.getElementById('urgentCheck-'   + i).checked = v.urgent   || false;
        document.getElementById('runsAndDrives-' + i).value = v.runsAndDrives === false ? 'no' : 'yes';
        document.getElementById('hasKeys-'       + i).value = v.hasKeys       === false ? 'no' : 'yes';

        // Restore photos
        if (v.photos?.length) {
          const preview = document.getElementById('photoPreview-' + i);
          v.photos.forEach((photo) => {
            const div = document.createElement('div');
            div.className = 'relative';
            div.innerHTML = `<img src="${photo.data}" class="rounded-lg border border-[var(--line)] object-cover h-24 w-full">
              <button class="absolute -top-2 -right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs"
                      onclick="removePhoto(this,${i})">×</button>`;
            preview.appendChild(div);
          });
        }
      }, 50);
    }

    function vehicleFormHTML(i, v) {
      return `
        <div id="vform-${i}" class="space-y-5 mt-5">
          <!-- Year / Make / Model -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 vehicle-ymm-grid">
            <div>
              <label class="label-dark">Year <span class="text-red-400">*</span></label>
              <div id="yearContainer-${i}"></div>
              <div id="yearError-${i}" class="error-msg"></div>
            </div>
            <div>
              <label class="label-dark">Make <span class="text-red-400">*</span></label>
              <input type="text" id="make-${i}" class="input-dark" autocomplete="off">
            </div>
            <div>
              <label class="label-dark">Model <span class="text-red-400">*</span></label>
              <input type="text" id="model-${i}" class="input-dark" autocomplete="off">
            </div>
          </div>

          <!-- VIN -->
          <div>
            <label class="label-dark">VIN (optional)</label>
            <input type="text" id="vin-${i}" maxlength="17" class="input-dark uppercase tracking-widest"
                   placeholder="1HGCM82633A123456" inputmode="text" autocomplete="off">
            <div id="vinResult-${i}" class="vin-result mt-2 text-sm hidden"></div>
            <div id="vinError-${i}"  class="vin-error  mt-2 text-sm hidden"></div>
          </div>

          <!-- Vehicle type -->
          <div>
            <label class="label-dark">Vehicle Type</label>
