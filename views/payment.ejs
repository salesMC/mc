    // ==================== TRANSPORT TOGGLE ====================
    function selectTransportStep(type) {
      formData.transportType = type;
      document.getElementById('tOpen')?.classList.toggle('active',     type === 'open');
      document.getElementById('tEnclosed')?.classList.toggle('active', type === 'enclosed');
    }

    // ==================== VALIDATION ====================
    function validateCurrentStep() {
      clearErrors();
      let valid = true;

      if (currentStep === 0) {
        if (!document.getElementById('fullName')?.value.trim()) { showError('fullName', 'Full name is required');    valid = false; }
        if (!document.getElementById('email')?.value.trim())    { showError('email',    'Email is required');        valid = false; }
        if (!document.getElementById('phone')?.value.trim())    { showError('phone',    'Phone is required');        valid = false; }

      } else if (currentStep === 1) {
        saveCurrentVehicleData();
        for (let i = 0; i < formData.vehicles.length; i++) {
          const v = formData.vehicles[i];
          if (!v.year || !v.make.trim() || !v.model.trim()) {
            valid = false;
            activeVehicleTab = i;
            renderVehicleTabs();
            renderVehicleForm(i);
            setTimeout(() => {
              if (!v.year)        showError('year-' + i,  'Year is required');
              if (!v.make.trim()) showError('make-' + i,  'Make is required');
              if (!v.model.trim()) showError('model-'+ i, 'Model is required');
            }, 80);
            break;
          }
        }

      } else if (currentStep === 2) {
        if (!document.getElementById('pickupAddr')?.value.trim())    { showError('pickupAddr',    'Pickup address required');  valid = false; }
        if (!document.getElementById('deliveryAddr')?.value.trim())  { showError('deliveryAddr',  'Delivery address required'); valid = false; }
        if (!document.getElementById('pickupDate')?.value)           { showError('pickupDate',    'Pickup date required');     valid = false; }
        if (!document.getElementById('mustDeliverBy')?.value)        { showError('mustDeliverBy', 'Deliver-by date required'); valid = false; }
      }
      return valid;
    }

    function showError(id, msg) {
      const errEl = document.getElementById(id + 'Error')
                 || document.getElementById('yearError-' + activeVehicleTab);
      if (errEl) errEl.textContent = msg;
      const input = document.getElementById(id);
      if (input) input.classList.add('error');
    }

    function clearErrors() {
      document.querySelectorAll('.error-msg').forEach(el => el.textContent = '');
      document.querySelectorAll('.input-dark').forEach(el => el.classList.remove('error'));
    }

    // ==================== RENDER STEP ====================
    function renderStep(step) {
      if (step > currentStep && !validateCurrentStep()) return;
      saveFormData();
      currentStep = step;

      if (step === 1) {
        document.getElementById('stepContent').innerHTML = `
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-5">Vehicle Details</h2>
          <div class="flex flex-nowrap gap-2 mb-3 overflow-x-auto pb-1 -webkit-overflow-scrolling-touch" id="vehicleTabs"
               style="WebkitOverflowScrolling:touch; scrollbar-width:none;"></div>
          <div id="vehicleFormContainer"></div>`;
        renderVehicleTabs();
        renderVehicleForm(activeVehicleTab);
        setTimeout(() => initPhotoUpload(activeVehicleTab), 100);
      } else {
        document.getElementById('stepContent').innerHTML = stepsHTML[step];
      }

      // Highlight active step in sidebar
      document.querySelectorAll('.step-item').forEach((el, i) => {
        el.classList.toggle('step-active', i === step);
      });

      // Prev / Next buttons
      document.getElementById('prevBtn').classList.toggle('hidden', step === 0);
      const nextBtn = document.getElementById('nextBtn');
      if (step === 4) {
        nextBtn.classList.add('hidden');
      } else {
        nextBtn.classList.remove('hidden');
        nextBtn.textContent = step === 3 ? 'Continue to Payment →' : 'Next →';
      }

      // Restore step-specific data
      if (step === 0) {
        document.getElementById('fullName').value = formData.contact.fullName;
        document.getElementById('email').value    = formData.contact.email;
        document.getElementById('phone').value    = formData.contact.phone;
      }

      if (step === 2) {
        setTimeout(() => {
          initGoogleAutocomplete();
          distanceService = new google.maps.DistanceMatrixService();
          document.getElementById('pickupAddr').value    = formData.location.pickup;
          document.getElementById('deliveryAddr').value  = formData.location.delivery;
          document.getElementById('pickupDate').value    = formData.pickupDate;
          document.getElementById('mustDeliverBy').value = formData.mustDeliverBy;
          selectTransportStep(formData.transportType);
        }, 100);
        calculateAndUpdateTotal();
      }

      if (step === 3) renderSummary();

      if (step === 4) {
        const t = document.getElementById('finalTotal2');
        if (t) t.textContent = '$' + formData.total.toLocaleString();
        const amtSpan = document.getElementById('stripe-pay-amount');
        if (amtSpan) amtSpan.textContent = '$' + formData.total.toLocaleString();
        setTimeout(() => initStripeElements(), 150);
      }

      // Scroll top of content on step change (mobile)
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function saveFormData() {
      if (currentStep === 0) {
        formData.contact = {
          fullName: document.getElementById('fullName')?.value.trim() || '',
          email:    document.getElementById('email')?.value.trim()    || '',
          phone:    document.getElementById('phone')?.value.trim()    || ''
        };
      } else if (currentStep === 1) {
        saveCurrentVehicleData();
      } else if (currentStep === 2) {
        formData.location = {
          pickup:   document.getElementById('pickupAddr')?.value.trim()   || '',
          delivery: document.getElementById('deliveryAddr')?.value.trim() || ''
        };
        formData.pickupDate    = document.getElementById('pickupDate')?.value    || '';
        formData.mustDeliverBy = document.getElementById('mustDeliverBy')?.value || '';
        calculateAndUpdateTotal();
      }
    }

    // ==================== SUMMARY ====================
    function renderSummary() {
      const miles = parseFloat(document.getElementById('distance')?.value) || 0;
      const vehicleRows = formData.vehicles.map((v, i) => {
        const price = calcVehiclePrice(miles, v);
        return `
          <div class="border-b border-[var(--line)] pb-3">
            <div class="font-semibold text-white mb-1">Vehicle ${i + 1}: ${v.year} ${v.make} ${v.model}</div>
            <div class="text-sm space-y-0.5 text-dim">
              <div>Type: ${v.type} &nbsp;|&nbsp; Condition: ${v.condition}</div>
              ${v.vin      ? `<div>VIN: ${v.vin}</div>` : ''}
              ${v.modified ? '<div>✓ Modified</div>'    : ''}
              ${v.urgent   ? '<div>✓ Urgent</div>'      : ''}
              <div class="text-[var(--orange)] font-semibold mt-1">Subtotal: $${price.toLocaleString()}</div>
            </div>
          </div>`;
      }).join('');

      // Compute subtotal before discount
      let subtotal = 0;
      formData.vehicles.forEach(v => { subtotal += calcVehiclePrice(miles, v); });
      let discountAmount = 0;
      if (appliedPromo) {
        discountAmount = appliedPromo.type === 'percent'
          ? Math.round(subtotal * appliedPromo.discount / 100)
          : Math.min(appliedPromo.discount, subtotal);
      }

      document.getElementById('summaryContent').innerHTML = `
        <div class="space-y-3">
          <div><strong class="text-white">Contact:</strong> ${formData.contact.fullName || '—'} · ${formData.contact.email || '—'}</div>
          <div><strong class="text-white">From:</strong> ${formData.location.pickup   || '—'}</div>
          <div><strong class="text-white">To:</strong>   ${formData.location.delivery || '—'}</div>
          <div><strong class="text-white">Transport:</strong> ${formData.transportType}</div>
          <div class="pt-2">
            <strong class="text-white block mb-3">Vehicles (${formData.vehicles.length}):</strong>
            <div class="space-y-3">${vehicleRows}</div>
          </div>
          <div id="promoDiscountLine" class="${appliedPromo && discountAmount > 0 ? '' : 'hidden'} pt-1"></div>
          <div class="pt-2 text-lg text-dim">
            Subtotal: <span class="${appliedPromo ? 'line-through opacity-50' : ''}">$${subtotal.toLocaleString()}</span>
          </div>
          <div class="text-2xl sm:text-3xl font-bold text-[var(--orange)]">
            Total: $${formData.total.toLocaleString()}
          </div>
        </div>`;

      // Re-render discount line
      updateDiscountLine(subtotal, discountAmount);

      // Restore promo UI state
      if (appliedPromo) {
        document.getElementById('promoApplied')?.classList.remove('hidden');
        document.getElementById('promoInputRow')?.classList.add('hidden');
        const label = document.getElementById('promoAppliedLabel');
        if (label) label.textContent = appliedPromo.code + ' — ' +
          (appliedPromo.type === 'percent' ? appliedPromo.discount + '% off' : '$' + appliedPromo.discount + ' off');
      }
    }

    // ==================== PROMO CODE ====================
    async function applyPromo() {
      const code = document.getElementById('promoCodeInput')?.value.trim().toUpperCase();
      const errorEl  = document.getElementById('promoError');
      const errorMsg = document.getElementById('promoErrorMsg');
      if (!code) return;

      errorEl?.classList.add('hidden');
      const btn = document.getElementById('promoApplyBtn');
      if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>'; }

      try {
        const res  = await fetch('/api/promo-codes/validate', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ code })
        });
        const data = await res.json();

        if (data.success) {
          appliedPromo = { code: data.code, discount: data.discount, type: data.type };
          calculateAndUpdateTotal();

          // Show applied badge, hide input
          document.getElementById('promoApplied')?.classList.remove('hidden');
          document.getElementById('promoInputRow')?.classList.add('hidden');
          const label = document.getElementById('promoAppliedLabel');
          if (label) label.textContent = data.code + ' — ' +
            (data.type === 'percent' ? data.discount + '% off' : '$' + data.discount + ' off');

          // Re-render summary totals
          renderSummary();
        } else {
          if (errorEl && errorMsg) { errorMsg.textContent = data.message || 'Invalid promo code'; errorEl.classList.remove('hidden'); }
        }
      } catch(e) {
        if (errorEl && errorMsg) { errorMsg.textContent = 'Error validating code. Try again.'; errorEl.classList.remove('hidden'); }
      } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = 'Apply'; }
      }
    }

    function removePromo() {
      appliedPromo = null;
      document.getElementById('promoApplied')?.classList.add('hidden');
      document.getElementById('promoInputRow')?.classList.remove('hidden');
      document.getElementById('promoCodeInput').value = '';
      calculateAndUpdateTotal();
      renderSummary();
    }

    // ==================== COMPLETE BOOKING ====================
    async function completeBooking(stripePaymentIntentId) {
      saveFormData();
      const orderData = {
        id: 'MC-' + Date.now().toString().slice(-6),
        status: 'New',
        contact: formData.contact,
        vehicles: formData.vehicles,
        vehicle: formData.vehicles[0],
        location: formData.location,
        pickupDate: formData.pickupDate,
        mustDeliverBy: formData.mustDeliverBy,
        transportType: formData.transportType,
        total: formData.total,
        promoCode: appliedPromo ? appliedPromo.code : null,
        promoDiscount: appliedPromo ? appliedPromo.discount : null,
        promoType: appliedPromo ? appliedPromo.type : null,
        stripePaymentIntentId: stripePaymentIntentId || null,
        createdAt: new Date().toISOString()
      };
      try {
        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(orderData)
        });
        if (res.ok) {
          window.location.href = '/quote-success';
        } else {
          showStripeError('Order save failed. Please contact support at (502) 417-8040.');
        }
      } catch (e) {
        console.error(e);
        showStripeError('Connection error. Please check your internet and try again.');
      }
    }

    function showStripeError(msg) {
      const err    = document.getElementById('stripe-error');
      const errMsg = document.getElementById('stripe-error-msg');
      if (err && errMsg) { errMsg.textContent = msg; err.classList.remove('hidden'); }
      document.getElementById('stripe-pay-btn')?.classList.remove('hidden');
      document.getElementById('stripe-loading')?.classList.add('hidden');
    }

    // ==================== STRIPE ====================
    const STRIPE_PK = '<%= process.env.STRIPE_PUBLISHABLE_KEY %>';
    let stripeInstance = null;
    let cardNumber, cardExpiry, cardCvc;

    function loadStripeSDK() {
      return new Promise((resolve, reject) => {
        if (window.Stripe) { resolve(); return; }
        const s = document.createElement('script');
        s.src     = 'https://js.stripe.com/v3/';
        s.onload  = resolve;
        s.onerror = () => reject(new Error('Failed to load Stripe'));
        document.head.appendChild(s);
      });
    }

    async function initStripeElements() {
      try {
        await loadStripeSDK();
        stripeInstance = Stripe(STRIPE_PK);
        const elements = stripeInstance.elements({ appearance: { theme: 'night' } });

        const style = {
          base: {
            color: '#FFFFFF',
            fontFamily: 'system-ui, -apple-system, sans-serif',
            fontSize: '16px',
            fontSmoothing: 'antialiased',
            '::placeholder': { color: '#8B949E' },
            iconColor: '#FF6A3D'
          },
          invalid: { color: '#F87171', iconColor: '#F87171' }
        };

        cardNumber = elements.create('cardNumber', { style, showIcon: true });
        cardExpiry = elements.create('cardExpiry', { style });
        cardCvc    = elements.create('cardCvc',    { style });

        cardNumber.mount('#stripe-card-number');
        cardExpiry.mount('#stripe-card-expiry');
        cardCvc.mount('#stripe-card-cvc');

        cardNumber.on('change', (e) => {
          const errEl = document.getElementById('stripe-error');
          if (e.error) showStripeError(e.error.message);
          else errEl?.classList.add('hidden');
        });
      } catch (e) {
        console.error('Stripe init error:', e);
        showStripeError('Payment system unavailable. Please contact us at (502) 417-8040.');
      }
    }

    async function submitStripePayment() {
      if (!stripeInstance || !cardNumber) {
        showStripeError('Payment not initialized. Please refresh the page.');
        return;
      }
      const name = document.getElementById('stripe-name')?.value.trim();
      if (!name) { showStripeError('Please enter the cardholder name.'); return; }

      document.getElementById('stripe-pay-btn')?.classList.add('hidden');
      document.getElementById('stripe-loading')?.classList.remove('hidden');
      document.getElementById('stripe-error')?.classList.add('hidden');

      try {
        const amountCents = Math.round(formData.total * 100);
        const intentRes   = await fetch('/api/create-payment-intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount: amountCents })
        });
        const intentData = await intentRes.json();
        if (!intentData.success) throw new Error(intentData.message || 'Failed to create payment');

        const { error, paymentIntent } = await stripeInstance.confirmCardPayment(intentData.clientSecret, {
          payment_method: {
            card: cardNumber,
            billing_details: {
              name,
              email: formData.contact.email || undefined,
              phone: formData.contact.phone || undefined
            }
          }
        });

        if (error) { showStripeError(error.message); return; }

        if (paymentIntent.status === 'succeeded') {
          await completeBooking(paymentIntent.id);
        } else {
          showStripeError('Payment not completed. Status: ' + paymentIntent.status);
        }
      } catch (e) {
        console.error('Payment error:', e);
        showStripeError(e.message || 'Payment failed. Please try again.');
      }
    }

    // ==================== NAV ====================
    function nextStep() {
      if (validateCurrentStep()) {
        saveFormData();
        if (currentStep < 4) renderStep(currentStep + 1);
      }
    }

    function prevStep() {
      saveFormData();
      if (currentStep > 0) renderStep(currentStep - 1);
    }

    function goToStep(step) {
      if (step > currentStep && !validateCurrentStep()) return;
      renderStep(step);
    }

    // ==================== INIT ====================
    window.addEventListener('load', () => {
      renderStep(0);

      const script  = document.createElement('script');
      script.src    = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyADY34xlNO8-qSU_2Lq7qZ7l1jydiRL74w&libraries=places';
      script.async  = true;
      script.defer  = true;
      document.head.appendChild(script);
    });
  </script>
</body>
</html>
