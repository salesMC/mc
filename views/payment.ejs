        year:         year.value || '',
        make:         document.getElementById('make-'  + i)?.value.trim() || '',
        model:        document.getElementById('model-' + i)?.value.trim() || '',
        vin:          document.getElementById('vin-'   + i)?.value.trim() || '',
        type:         document.getElementById('vehicleType-' + i)?.value || 'sedan',
        condition:    document.querySelector(`input[name="condition-${i}"]:checked`)?.value || 'operable',
        modified:     document.getElementById('modifiedCheck-' + i)?.checked || false,
        urgent:       document.getElementById('urgentCheck-'   + i)?.checked || false,
        runsAndDrives: document.getElementById('runsAndDrives-'+ i)?.value !== 'no',
