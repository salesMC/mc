<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Request a Quote | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .step-active {
      border-color: #FF6A3D;
      background: rgba(255,106,61,0.1);
      color: white;
    }
    .input-dark {
      width: 100%;
      padding: 0.95rem 1.25rem;
      background: #161B22;
      border: 1px solid #1F2937;
      border-radius: 0.5rem;
      color: white;
      transition: all 0.2s ease;
      font-size: 1rem;
      outline: none;
    }
    .input-dark::placeholder { color: #8B949E; }
    .input-dark:focus {
      border-color: #FF6A3D;
      box-shadow: 0 0 0 3px rgba(255,106,61,0.15);
    }
    .input-dark.error {
      border-color: #ef4444 !important;
      box-shadow: 0 0 0 3px rgba(239,68,68,0.2) !important;
    }
    .label-dark {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: #8B949E;
      margin-bottom: 0.5rem;
    }
    .error-msg {
      color: #ef4444;
      font-size: 0.8rem;
      margin-top: 4px;
      min-height: 20px;
    }
    .vin-result { color: #BEF264; font-weight: 500; }
    .vin-error  { color: #F87171; }

    .btn-transport { transition: all 0.2s; }
    .btn-transport.active {
      background: #FF6A3D;
      color: white;
      border-color: #FF6A3D;
    }

    .upload-zone {
      border: 2px dashed #374151;
      background: #161B22;
      border-radius: 12px;
      transition: all 0.2s ease;
    }
    .upload-zone:hover { border-color: #FF6A3D; background: #1F2937; }

    /* Vehicle tabs */
    .vehicle-tab {
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid #1F2937;
      color: #8B949E;
      background: #161B22;
      cursor: pointer;
      transition: all 0.18s ease;
      white-space: nowrap;
    }
    .vehicle-tab.active {
      border-color: #FF6A3D;
      color: white;
      background: rgba(255,106,61,0.12);
    }
    .vehicle-tab:hover:not(.active) { border-color: #374151; color: #C9D1D9; }

    .add-vehicle-tab {
      padding: 0.5rem 0.85rem;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px dashed rgba(255,106,61,0.4);
      color: var(--orange);
      background: rgba(255,106,61,0.04);
      cursor: pointer;
      transition: all 0.18s ease;
    }
    .add-vehicle-tab:hover { border-color: #FF6A3D; background: rgba(255,106,61,0.1); }

    .remove-vtab {
      margin-left: 0.4rem;
      opacity: 0.5;
      transition: opacity 0.15s;
    }
    .remove-vtab:hover { opacity: 1; color: #ef4444; }

    @media (max-width: 640px) {
      .step-item { padding: 0.75rem 1rem !important; font-size: 0.95rem; }
      .tile { padding: 1.5rem !important; }
    }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <main class="relative overflow-hidden py-12 bg-deep min-h-screen">
    <div class="glow-orange" style="top: -100px; left: -120px;"></div>
    <div class="glow-cyan" style="bottom: -80px; right: -100px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-8">

        <!-- Sidebar -->
        <div class="lg:col-span-4 xl:col-span-3">
          <div class="tile p-6 lg:p-8 sticky top-24">
            <h2 class="text-2xl font-bold text-white mb-8">Request a Quote</h2>
            <div id="steps" class="space-y-2">
              <div onclick="goToStep(0)" class="step-item flex items-center gap-3 cursor-pointer p-4 rounded-xl step-active text-sm" data-step="0">
                <span class="font-mono text-orange-400">1</span> Contact
              </div>
              <div onclick="goToStep(1)" class="step-item flex items-center gap-3 cursor-pointer p-4 rounded-xl text-sm" data-step="1">
                <span class="font-mono text-orange-400">2</span> Vehicles
              </div>
              <div onclick="goToStep(2)" class="step-item flex items-center gap-3 cursor-pointer p-4 rounded-xl text-sm" data-step="2">
                <span class="font-mono text-orange-400">3</span> Route
              </div>
              <div onclick="goToStep(3)" class="step-item flex items-center gap-3 cursor-pointer p-4 rounded-xl text-sm" data-step="3">
                <span class="font-mono text-orange-400">4</span> Summary
              </div>
              <div onclick="goToStep(4)" class="step-item flex items-center gap-3 cursor-pointer p-4 rounded-xl text-sm" data-step="4">
                <span class="font-mono text-orange-400">5</span> Payment
              </div>
            </div>

            <div class="mt-12 pt-8 border-t border-[var(--line)]">
              <div class="text-sm text-muted">Estimated Total</div>
              <div id="totalPriceSidebar" class="text-4xl lg:text-5xl font-bold text-[var(--orange)] mt-1">$0</div>
              <div id="vehicleCountSidebar" class="text-xs text-muted mt-1"></div>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-8 xl:col-span-9">
          <div class="tile p-6 md:p-10 lg:p-12 min-h-[620px]" id="stepContent"></div>

          <div class="flex flex-col sm:flex-row justify-between gap-4 mt-8">
            <button onclick="prevStep()" id="prevBtn"
                    class="btn btn-ghost px-8 py-4 hidden w-full sm:w-auto">
              ← Previous
            </button>
            <button onclick="nextStep()" id="nextBtn"
                    class="btn btn-primary px-10 py-4 w-full sm:w-auto">
              Next →
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // ==================== CONFIG ====================
    let calculatorConfig = {
      baseFee: 120,
      tiers: [{ max: 30, rate: 3.00 }, { max: 70, rate: 2.20 }, { max: 110, rate: 1.80 },
              { max: 160, rate: 1.50 }, { max: Infinity, rate: 1.30 }],
      multipliers: { sedan: 1.00, 'mid-suv': 1.10, 'full-suv': 1.20, 'pickup': 1.15, 'cargo-van': 1.25, 'passenger-van': 1.25, 'other': 1.20 },
      addons: { inoperable: 75, modified: 100, urgent: 100 }
    };
    const savedCfg = localStorage.getItem('calculatorConfig');
    if (savedCfg) calculatorConfig = JSON.parse(savedCfg);

    let currentStep = 0;
    let fromAutocomplete, toAutocomplete, distanceService;
    let activeVehicleTab = 0; // index in vehicles array

    let formData = {
      contact: { fullName: '', email: '', phone: '' },
      vehicles: [freshVehicle()],   // array of vehicles
      location: { pickup: '', delivery: '' },
      pickupDate: '', mustPickupBy: '',
      transportType: 'open',
      total: 0
    };

    function freshVehicle() {
      return { year: '', make: '', model: '', vin: '', type: 'sedan', condition: 'operable', modified: false, urgent: false, runsAndDrives: true, hasKeys: true, photos: [] };
    }

    // ==================== VIN DECODER ====================
    async function decodeVIN(vin) {
      try {
        const res = await fetch(`https://vpic.nhtsa.dot.gov/api/vehicles/decodevinvalues/${vin}?format=json`);
        const data = await res.json();
        return data.Results && data.Results[0] ? data.Results[0] : null;
      } catch (e) { return null; }
    }

    // ==================== GOOGLE MAPS ====================
    function initGoogleAutocomplete() {
      const options = { types: ['address'], componentRestrictions: { country: 'us' } };
      fromAutocomplete = new google.maps.places.Autocomplete(document.getElementById('pickupAddr'), options);
      toAutocomplete = new google.maps.places.Autocomplete(document.getElementById('deliveryAddr'), options);
      fromAutocomplete.addListener('place_changed', calculateDistance);
      toAutocomplete.addListener('place_changed', calculateDistance);
    }

    function calculateDistance() {
      const pickup   = document.getElementById('pickupAddr').value.trim();
      const delivery = document.getElementById('deliveryAddr').value.trim();
      if (!pickup || !delivery || !distanceService) return;
      distanceService.getDistanceMatrix({
        origins: [pickup], destinations: [delivery],
        travelMode: google.maps.TravelMode.DRIVING,
        unitSystem: google.maps.UnitSystem.IMPERIAL
      }, (response, status) => {
        if (status === 'OK' && response.rows[0].elements[0].status === 'OK') {
          const miles = Math.round(response.rows[0].elements[0].distance.value * 0.000621371);
          document.getElementById('distance').value = miles;
          calculateAndUpdateTotal();
        }
      });
    }

    // ==================== PRICE CALCULATION ====================
    function calcVehiclePrice(miles, v) {
      let cpm = calculatorConfig.tiers[calculatorConfig.tiers.length - 1].rate;
      for (let tier of calculatorConfig.tiers) { if (miles <= tier.max) { cpm = tier.rate; break; } }
      let subtotal = calculatorConfig.baseFee + (cpm * miles);
      if (calculatorConfig.multipliers[v.type]) subtotal *= calculatorConfig.multipliers[v.type];
      if (v.condition === 'inoperable') subtotal += calculatorConfig.addons.inoperable;
      if (v.modified) subtotal += calculatorConfig.addons.modified;
      if (v.urgent)   subtotal += calculatorConfig.addons.urgent;
      return Math.round(subtotal);
    }

    function calculateAndUpdateTotal() {
      const miles = parseFloat(document.getElementById('distance')?.value) || 0;
      let grand = 0;
      formData.vehicles.forEach(v => { grand += calcVehiclePrice(miles, v); });
      formData.total = grand;
      document.getElementById('totalPriceSidebar').textContent = '$' + grand.toLocaleString();
      document.getElementById('vehicleCountSidebar').textContent = formData.vehicles.length > 1 ? formData.vehicles.length + ' vehicles' : '';
      if (document.getElementById('finalTotal2')) {
        document.getElementById('finalTotal2').textContent = '$' + grand.toLocaleString();
      }
    }

    // ==================== PHOTO UPLOAD ====================
    function initPhotoUpload(vehicleIndex) {
      const oldInput = document.getElementById('vehiclePhotos-' + vehicleIndex);
      if (!oldInput) return;

      // Clone to remove any previous event listeners
      const input = oldInput.cloneNode(true);
      oldInput.parentNode.replaceChild(input, oldInput);

      const preview = document.getElementById('photoPreview-' + vehicleIndex);

      input.addEventListener('change', () => {
        Array.from(input.files).forEach(file => {
          if (formData.vehicles[vehicleIndex].photos.length >= 8) return alert("Maximum 8 photos allowed");
          if (!file.type.startsWith('image/')) return;
          const reader = new FileReader();
          reader.onload = (e) => {
            formData.vehicles[vehicleIndex].photos.push({ name: file.name, data: e.target.result });
            const div = document.createElement('div');
            div.className = 'relative';
            div.innerHTML = `<img src="${e.target.result}" class="rounded-lg border border-[var(--line)] object-cover h-24 w-full"><button class="absolute -top-2 -right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs" onclick="removePhoto(this, ${vehicleIndex})">×</button>`;
            preview.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
        // Reset input so same file can be re-selected
        input.value = '';
      });
    }

    window.removePhoto = function(el, vehicleIndex) {
      const index = Array.from(document.getElementById('photoPreview-' + vehicleIndex).children).indexOf(el.parentElement);
      if (index > -1) formData.vehicles[vehicleIndex].photos.splice(index, 1);
      el.parentElement.remove();
    };

    // ==================== YEAR SELECT ====================
    function createYearSelect(id) {
      const select = document.createElement('select');
      select.id = id;
      select.className = 'input-dark';
      select.required = true;
      const defaultOpt = document.createElement('option');
      defaultOpt.value = '';
      defaultOpt.textContent = 'Select year';
      select.appendChild(defaultOpt);
      for (let y = 2030; y >= 1900; y--) {
        const opt = document.createElement('option');
        opt.value = y;
        opt.textContent = y;
        select.appendChild(opt);
      }
      return select;
    }

    // ==================== VEHICLE TABS ====================
    function renderVehicleTabs() {
      const container = document.getElementById('vehicleTabs');
      if (!container) return;
      container.innerHTML = '';

      formData.vehicles.forEach((v, i) => {
        const tab = document.createElement('button');
        tab.type = 'button';
        tab.className = 'vehicle-tab' + (i === activeVehicleTab ? ' active' : '');
        tab.innerHTML = `Vehicle ${i + 1}${formData.vehicles.length > 1 ? ` <span class="remove-vtab" onclick="removeVehicleTab(event, ${i})">×</span>` : ''}`;
        tab.addEventListener('click', (e) => {
          if (e.target.classList.contains('remove-vtab')) return;
          saveCurrentVehicleData();
          activeVehicleTab = i;
          renderVehicleTabs();
          renderVehicleForm(i);
        });
        container.appendChild(tab);
      });

      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      addBtn.className = 'add-vehicle-tab';
      addBtn.innerHTML = '<i class="fas fa-plus"></i> Add Vehicle';
      addBtn.onclick = () => {
        saveCurrentVehicleData();
        formData.vehicles.push(freshVehicle());
        activeVehicleTab = formData.vehicles.length - 1;
        renderVehicleTabs();
        renderVehicleForm(activeVehicleTab);
        // renderVehicleForm handles yearSelect + VIN + photos internally
      };
      container.appendChild(addBtn);
    }

    window.removeVehicleTab = function(e, i) {
      e.stopPropagation();
      if (formData.vehicles.length <= 1) return;
      formData.vehicles.splice(i, 1);
      if (activeVehicleTab >= formData.vehicles.length) activeVehicleTab = formData.vehicles.length - 1;
      renderVehicleTabs();
      renderVehicleForm(activeVehicleTab);
      setTimeout(() => initPhotoUpload(activeVehicleTab), 50);
      setTimeout(() => {
        const yc = document.getElementById('yearContainer-' + activeVehicleTab);
        if (yc && !yc.querySelector('select')) {
          yc.appendChild(createYearSelect('year-' + activeVehicleTab));
        }
        initVehicleVIN(activeVehicleTab);
      }, 60);
    };

    function renderVehicleForm(i) {
      const v = formData.vehicles[i];
      const formContainer = document.getElementById('vehicleFormContainer');
      if (!formContainer) return;
      formContainer.innerHTML = vehicleFormHTML(i, v);
      setTimeout(() => {
        const yc = document.getElementById('yearContainer-' + i);
        yc.innerHTML = ''; // clear before appending to prevent duplicates
        yc.appendChild(createYearSelect('year-' + i));
        const yearSelect = document.getElementById('year-' + i);
        if (v.year) yearSelect.value = v.year;
        initPhotoUpload(i);
        initVehicleVIN(i);
        // restore values
        const make = document.getElementById('make-' + i);
        const model = document.getElementById('model-' + i);
        if (make) make.value = v.make || '';
        if (model) model.value = v.model || '';
        document.getElementById('vehicleType-' + i).value = v.type || 'sedan';
        const condEl = document.querySelector(`input[name="condition-${i}"][value="${v.condition || 'operable'}"]`);
        if (condEl) condEl.checked = true;
        document.getElementById('modifiedCheck-' + i).checked = v.modified || false;
        document.getElementById('urgentCheck-' + i).checked = v.urgent || false;
        document.getElementById('runsAndDrives-' + i).value = v.runsAndDrives === false ? 'no' : 'yes';
        document.getElementById('hasKeys-' + i).value = v.hasKeys === false ? 'no' : 'yes';
        // restore photos
        if (v.photos && v.photos.length) {
          const preview = document.getElementById('photoPreview-' + i);
          v.photos.forEach((photo, idx) => {
            const div = document.createElement('div');
            div.className = 'relative';
            div.innerHTML = `<img src="${photo.data}" class="rounded-lg border border-[var(--line)] object-cover h-24 w-full"><button class="absolute -top-2 -right-2 bg-red-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs" onclick="removePhoto(this, ${i})">×</button>`;
            preview.appendChild(div);
          });
        }
      }, 50);
    }

    function vehicleFormHTML(i, v) {
      return `
        <div id="vform-${i}" class="space-y-6 mt-6">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div><label class="label-dark">Year <span class="text-red-400">*</span></label><div id="yearContainer-${i}"></div><div id="yearError-${i}" class="error-msg"></div></div>
            <div><label class="label-dark">Make <span class="text-red-400">*</span></label><input type="text" id="make-${i}" class="input-dark" required></div>
            <div><label class="label-dark">Model <span class="text-red-400">*</span></label><input type="text" id="model-${i}" class="input-dark" required></div>
          </div>
          <div>
            <label class="label-dark">VIN (optional)</label>
            <input type="text" id="vin-${i}" maxlength="17" class="input-dark uppercase tracking-widest" placeholder="1HGCM82633A123456">
            <div id="vinResult-${i}" class="vin-result mt-2 text-sm hidden"></div>
            <div id="vinError-${i}" class="vin-error mt-2 text-sm hidden"></div>
          </div>
          <div>
            <label class="label-dark">Vehicle Type</label>
            <select id="vehicleType-${i}" onchange="formData.vehicles[${i}].type=this.value; calculateAndUpdateTotal()" class="input-dark">
              <option value="sedan">Sedan / Compact SUV</option>
              <option value="mid-suv">Mid-size SUV</option>
              <option value="full-suv">Full-size SUV</option>
              <option value="pickup">Pick-up Truck</option>
              <option value="cargo-van">Cargo Van</option>
              <option value="passenger-van">Passenger Van</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="flex flex-wrap gap-6">
            <label class="flex items-center gap-2"><input type="radio" name="condition-${i}" value="operable" ${(!v.condition || v.condition==='operable') ? 'checked' : ''} onchange="formData.vehicles[${i}].condition=this.value; calculateAndUpdateTotal()"> Operable</label>
            <label class="flex items-center gap-2"><input type="radio" name="condition-${i}" value="inoperable" ${v.condition==='inoperable' ? 'checked' : ''} onchange="formData.vehicles[${i}].condition=this.value; calculateAndUpdateTotal()"> Inoperable</label>
          </div>
          <div class="grid grid-cols-2 gap-6">
            <div><label class="label-dark">Runs and drives</label><select id="runsAndDrives-${i}" class="input-dark"><option value="yes">Yes</option><option value="no">No</option></select></div>
            <div><label class="label-dark">Has keys</label><select id="hasKeys-${i}" class="input-dark"><option value="yes">Yes</option><option value="no">No</option></select></div>
          </div>
          <div class="space-y-3">
            <label class="flex items-center gap-3"><input type="checkbox" id="modifiedCheck-${i}" onchange="formData.vehicles[${i}].modified=this.checked; calculateAndUpdateTotal()"> Modified / Custom vehicle</label>
            <label class="flex items-center gap-3"><input type="checkbox" id="urgentCheck-${i}" onchange="formData.vehicles[${i}].urgent=this.checked; calculateAndUpdateTotal()"> Urgent Delivery</label>
          </div>
          <div>
            <label class="label-dark">Vehicle Photos (optional)</label>
            <div class="upload-zone p-8 text-center">
              <input type="file" id="vehiclePhotos-${i}" accept="image/*" multiple class="hidden">
              <label for="vehiclePhotos-${i}" class="cursor-pointer block">
                <i class="fas fa-cloud-upload-alt text-4xl text-[var(--orange)] mb-3"></i>
                <span class="font-medium text-[var(--orange)]">Upload photos</span>
              </label>
            </div>
            <div id="photoPreview-${i}" class="mt-4 grid grid-cols-2 md:grid-cols-3 gap-3"></div>
          </div>
        </div>
      `;
    }

    function initVehicleVIN(i) {
      const vinInput = document.getElementById('vin-' + i);
      if (!vinInput) return;
      vinInput.addEventListener('input', async () => {
        const vin = vinInput.value.trim().toUpperCase();
        const resultDiv = document.getElementById('vinResult-' + i);
        const errorDiv  = document.getElementById('vinError-' + i);
        resultDiv.classList.add('hidden');
        errorDiv.classList.add('hidden');
        if (vin.length === 17) {
          const vehicle = await decodeVIN(vin);
          if (vehicle && vehicle.Make) {
            resultDiv.textContent = `${vehicle.ModelYear || ''} ${vehicle.Make} ${vehicle.Model || ''}`;
            resultDiv.classList.remove('hidden');
            if (vehicle.ModelYear) document.getElementById('year-' + i).value = vehicle.ModelYear;
            if (vehicle.Make)      document.getElementById('make-' + i).value = vehicle.Make;
            if (vehicle.Model)     document.getElementById('model-' + i).value = vehicle.Model;
          } else {
            errorDiv.textContent = 'Could not decode VIN';
            errorDiv.classList.remove('hidden');
          }
        }
      });
    }

    function saveCurrentVehicleData() {
      const i = activeVehicleTab;
      const year = document.getElementById('year-' + i);
      const make = document.getElementById('make-' + i);
      const model = document.getElementById('model-' + i);
      const vin = document.getElementById('vin-' + i);
      const vtype = document.getElementById('vehicleType-' + i);
      const cond = document.querySelector(`input[name="condition-${i}"]:checked`);
      const mod = document.getElementById('modifiedCheck-' + i);
      const urgent = document.getElementById('urgentCheck-' + i);
      const rad = document.getElementById('runsAndDrives-' + i);
      const hk = document.getElementById('hasKeys-' + i);

      if (!year) return;
      formData.vehicles[i] = {
        ...formData.vehicles[i],
        year:  year?.value || '',
        make:  make?.value.trim() || '',
        model: model?.value.trim() || '',
        vin:   vin?.value.trim() || '',
        type:  vtype?.value || 'sedan',
        condition: cond?.value || 'operable',
        modified: mod?.checked || false,
        urgent:   urgent?.checked || false,
        runsAndDrives: rad?.value !== 'no',
        hasKeys:       hk?.value !== 'no',
      };
    }

    // ==================== STEPS ====================
    const stepsHTML = [
      // 0 Contact
      `<h2 class="text-2xl md:text-3xl font-bold text-white mb-8">Contact Information</h2>
       <div class="space-y-6">
         <div><label class="label-dark">Full Name <span class="text-red-400">*</span></label><input type="text" id="fullName" class="input-dark" required><div id="fullNameError" class="error-msg"></div></div>
         <div><label class="label-dark">Email <span class="text-red-400">*</span></label><input type="email" id="email" class="input-dark" required><div id="emailError" class="error-msg"></div></div>
         <div><label class="label-dark">Phone <span class="text-red-400">*</span></label><input type="tel" id="phone" class="input-dark" required><div id="phoneError" class="error-msg"></div></div>
       </div>`,

      // 1 Vehicles (built dynamically)
      `__VEHICLES__`,

      // 2 Route
      `<h2 class="text-2xl md:text-3xl font-bold text-white mb-8">Route & Pickup Dates</h2>
       <div class="space-y-6">
         <div><label class="label-dark">Pickup Address <span class="text-red-400">*</span></label><input type="text" id="pickupAddr" class="input-dark" required></div>
         <div><label class="label-dark">Delivery Address <span class="text-red-400">*</span></label><input type="text" id="deliveryAddr" class="input-dark" required></div>
         <div><label class="label-dark">Distance (miles)</label><input type="number" id="distance" class="input-dark" oninput="calculateAndUpdateTotal()"></div>
         <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
           <div><label class="label-dark">First possible pickup <span class="text-red-400">*</span></label><input type="date" id="pickupDate" class="input-dark" required></div>
           <div><label class="label-dark">Must pickup by <span class="text-red-400">*</span></label><input type="date" id="mustPickupBy" class="input-dark" required></div>
         </div>
         <div>
           <label class="label-dark">Transport Type</label>
           <div class="flex gap-3 mt-1">
             <button type="button" id="tOpen" onclick="selectTransportStep('open')" class="btn-transport flex-1 py-4 border-2 rounded-lg active">Open</button>
             <button type="button" id="tEnclosed" onclick="selectTransportStep('enclosed')" class="btn-transport flex-1 py-4 border-2 rounded-lg">Enclosed</button>
           </div>
         </div>
       </div>`,

      // 3 Summary
      `<h2 class="text-2xl md:text-3xl font-bold text-white mb-8">Order Summary</h2>
       <div id="summaryContent" class="bg-deep p-8 rounded-2xl space-y-4 text-dim"></div>`,

      // 4 Payment
      `<h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Secure Payment</h2>
       <p class="text-dim mb-8">Your order will be created after payment is confirmed.</p>

       <div class="bg-deep border border-[var(--line)] rounded-xl p-6 mb-8 flex items-center justify-between">
         <div>
           <div class="text-sm text-muted mb-1">Order Total</div>
           <div class="text-4xl font-bold text-[var(--orange)]" id="finalTotal2"></div>
         </div>
         <div class="flex items-center gap-2 text-muted text-xs">
           <i class="fas fa-lock text-[var(--lime)]"></i>
           SSL Secured · Powered by Stripe
         </div>
       </div>

       <div id="stripe-form">
         <div class="space-y-5">
           <div>
             <label class="label-dark">Card Number</label>
             <div id="stripe-card-number" class="input-dark" style="padding-top:0.85rem;padding-bottom:0.85rem;"></div>
           </div>
           <div class="grid grid-cols-2 gap-4">
             <div>
               <label class="label-dark">Expiry Date</label>
               <div id="stripe-card-expiry" class="input-dark" style="padding-top:0.85rem;padding-bottom:0.85rem;"></div>
             </div>
             <div>
               <label class="label-dark">CVC</label>
               <div id="stripe-card-cvc" class="input-dark" style="padding-top:0.85rem;padding-bottom:0.85rem;"></div>
             </div>
           </div>
           <div>
             <label class="label-dark">Cardholder Name</label>
             <input type="text" id="stripe-name" placeholder="John Smith" class="input-dark">
           </div>
         </div>

         <div id="stripe-error" class="hidden mt-4 bg-red-900/30 border border-red-500/40 rounded-xl p-4 text-red-400 text-sm flex items-center gap-2">
           <i class="fas fa-circle-exclamation flex-shrink-0"></i>
           <span id="stripe-error-msg"></span>
         </div>

         <button id="stripe-pay-btn" onclick="submitStripePayment()"
                 class="btn btn-primary w-full justify-center py-5 text-base font-semibold mt-6">
           <i class="fas fa-lock mr-2"></i>
           Pay <span id="stripe-pay-amount"></span> Securely
         </button>

         <div id="stripe-loading" class="hidden text-center py-4 mt-2">
           <i class="fas fa-circle-notch fa-spin text-2xl text-[var(--orange)] mb-2 block"></i>
           <span class="text-dim text-sm">Processing payment…</span>
         </div>

         <p class="text-xs text-muted text-center mt-5 flex items-center justify-center gap-2">
           <i class="fab fa-stripe text-lg"></i>
           Payments processed securely by Stripe. We never store your card details.
         </p>
         <div class="flex items-center justify-center gap-4 mt-4 opacity-40">
           <i class="fab fa-cc-visa text-2xl text-white"></i>
           <i class="fab fa-cc-mastercard text-2xl text-white"></i>
           <i class="fab fa-cc-amex text-2xl text-white"></i>
           <i class="fab fa-cc-discover text-2xl text-white"></i>
         </div>
       </div>`
    ];

    function selectTransportStep(type) {
      formData.transportType = type;
      const tOpen     = document.getElementById('tOpen');
      const tEnclosed = document.getElementById('tEnclosed');
      if (tOpen)     tOpen.classList.toggle('active', type === 'open');
      if (tEnclosed) tEnclosed.classList.toggle('active', type === 'enclosed');
    }

    // ==================== VALIDATION ====================
    function validateCurrentStep() {
      clearErrors();
      let valid = true;

      if (currentStep === 0) {
        if (!document.getElementById('fullName')?.value.trim()) { showError('fullName', 'Full name is required'); valid = false; }
        if (!document.getElementById('email')?.value.trim())    { showError('email', 'Email is required'); valid = false; }
        if (!document.getElementById('phone')?.value.trim())    { showError('phone', 'Phone is required'); valid = false; }
      } else if (currentStep === 1) {
        saveCurrentVehicleData();
        for (let i = 0; i < formData.vehicles.length; i++) {
          const v = formData.vehicles[i];
          if (!v.year || !v.make.trim() || !v.model.trim()) {
            valid = false;
            // Switch to the offending tab to highlight
            activeVehicleTab = i;
            renderVehicleTabs();
            renderVehicleForm(i);
            setTimeout(() => {
              if (!v.year) showError('year-' + i, 'Year is required');
            }, 60);
            break;
          }
        }
      } else if (currentStep === 2) {
        if (!document.getElementById('pickupAddr')?.value.trim())   { showError('pickupAddr', 'Pickup address required'); valid = false; }
        if (!document.getElementById('deliveryAddr')?.value.trim()) { showError('deliveryAddr', 'Delivery address required'); valid = false; }
        if (!document.getElementById('pickupDate')?.value)          { showError('pickupDate', 'Pickup date required'); valid = false; }
        if (!document.getElementById('mustPickupBy')?.value)        { showError('mustPickupBy', 'Must pickup by date required'); valid = false; }
      }
      return valid;
    }

    function showError(id, msg) {
      const err = document.getElementById(id + 'Error') || document.getElementById('yearError-' + activeVehicleTab);
      if (err) err.textContent = msg;
      const input = document.getElementById(id);
      if (input) input.classList.add('error');
    }

    function clearErrors() {
      document.querySelectorAll('.error-msg').forEach(el => el.textContent = '');
      document.querySelectorAll('.input-dark').forEach(el => el.classList.remove('error'));
    }

    // ==================== RENDER ====================
    function renderStep(step) {
      if (step > currentStep && !validateCurrentStep()) return;
      saveFormData();
      currentStep = step;

      if (step === 1) {
        // Build vehicle step HTML
        document.getElementById('stepContent').innerHTML = `
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">Vehicle Details</h2>
          <div class="flex flex-wrap gap-2 mb-2" id="vehicleTabs"></div>
          <div id="vehicleFormContainer"></div>
        `;
        renderVehicleTabs();
        renderVehicleForm(activeVehicleTab);
        setTimeout(() => initPhotoUpload(activeVehicleTab), 100);
      } else {
        document.getElementById('stepContent').innerHTML = stepsHTML[step];
      }

      document.querySelectorAll('.step-item').forEach((el, i) => {
        el.classList.toggle('step-active', i === step);
      });
      document.getElementById('prevBtn').classList.toggle('hidden', step === 0);
      const nextBtnEl = document.getElementById('nextBtn');
      if (step === 4) {
        nextBtnEl.classList.add('hidden');
      } else {
        nextBtnEl.classList.remove('hidden');
        nextBtnEl.textContent = 'Next →';
      }

      if (step === 0) {
        const fn = document.getElementById('fullName');
        const em = document.getElementById('email');
        const ph = document.getElementById('phone');
        if (fn) fn.value = formData.contact.fullName;
        if (em) em.value = formData.contact.email;
        if (ph) ph.value = formData.contact.phone;
      }

      if (step === 2) {
        setTimeout(() => {
          initGoogleAutocomplete();
          distanceService = new google.maps.DistanceMatrixService();
          document.getElementById('pickupAddr').value   = formData.location.pickup;
          document.getElementById('deliveryAddr').value = formData.location.delivery;
          document.getElementById('pickupDate').value   = formData.pickupDate;
          document.getElementById('mustPickupBy').value = formData.mustPickupBy;
          selectTransportStep(formData.transportType);
        }, 100);
        calculateAndUpdateTotal();
      }

      if (step === 3) renderSummary();
      if (step === 4) {
        const t = document.getElementById('finalTotal2');
        if (t) t.textContent = '$' + formData.total.toLocaleString();
        const amtSpan = document.getElementById('stripe-pay-amount');
        if (amtSpan) amtSpan.textContent = '$' + formData.total.toLocaleString();
        setTimeout(() => initStripeElements(), 150);
      }
    }

    function saveFormData() {
      if (currentStep === 0) {
        formData.contact = {
          fullName: document.getElementById('fullName')?.value.trim() || '',
          email:    document.getElementById('email')?.value.trim() || '',
          phone:    document.getElementById('phone')?.value.trim() || ''
        };
      } else if (currentStep === 1) {
        saveCurrentVehicleData();
      } else if (currentStep === 2) {
        formData.location = {
          pickup:   document.getElementById('pickupAddr')?.value.trim() || '',
          delivery: document.getElementById('deliveryAddr')?.value.trim() || ''
        };
        formData.pickupDate   = document.getElementById('pickupDate')?.value || '';
        formData.mustPickupBy = document.getElementById('mustPickupBy')?.value || '';
        formData.transportType = formData.transportType || 'open';
        calculateAndUpdateTotal();
      }
    }

    function renderSummary() {
      const miles = parseFloat(document.getElementById('distance')?.value) || 0;
      let vehicleRows = formData.vehicles.map((v, i) => {
        const price = calcVehiclePrice(miles, v);
        return `
          <div class="border-b border-[var(--line)] pb-3">
            <div class="font-semibold text-white mb-1">Vehicle ${i + 1}: ${v.year} ${v.make} ${v.model}</div>
            <div class="text-sm space-y-0.5">
              <div>Type: ${v.type} | Condition: ${v.condition}</div>
              ${v.vin ? `<div>VIN: ${v.vin}</div>` : ''}
              ${v.modified ? '<div>✓ Modified</div>' : ''}
              ${v.urgent   ? '<div>✓ Urgent</div>' : ''}
              <div class="text-[var(--orange)] font-semibold mt-1">Subtotal: $${price.toLocaleString()}</div>
            </div>
          </div>
        `;
      }).join('');

      const html = `
        <div class="space-y-4">
          <div><strong class="text-white">Contact:</strong> ${formData.contact.fullName || '—'} · ${formData.contact.email || '—'}</div>
          <div><strong class="text-white">From:</strong> ${formData.location.pickup || '—'}</div>
          <div><strong class="text-white">To:</strong> ${formData.location.delivery || '—'}</div>
          <div><strong class="text-white">Transport:</strong> ${formData.transportType}</div>
          <div class="pt-2">
            <strong class="text-white block mb-3">Vehicles (${formData.vehicles.length}):</strong>
            <div class="space-y-3">${vehicleRows}</div>
          </div>
          <div class="pt-4 text-3xl font-bold text-[var(--orange)]">Total: $${formData.total.toLocaleString()}</div>
        </div>
      `;
      document.getElementById('summaryContent').innerHTML = html;
    }

    // Called ONLY after Stripe payment succeeds
    async function completeBooking(stripePaymentIntentId) {
      saveFormData();
      const orderData = {
        id: 'MC-' + Date.now().toString().slice(-6),
        status: 'New',
        contact: formData.contact,
        vehicles: formData.vehicles,
        vehicle: formData.vehicles[0],
        location: formData.location,
        pickupDate: formData.pickupDate,
        mustPickupBy: formData.mustPickupBy,
        transportType: formData.transportType,
        total: formData.total,
        stripePaymentIntentId: stripePaymentIntentId || null,
        createdAt: new Date().toISOString()
      };
      try {
        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(orderData)
        });
        if (res.ok) {
          window.location.href = '/quote-success';
        } else {
          showStripeError('Order save failed. Please contact support at (502) 417-8040.');
        }
      } catch (e) {
        console.error(e);
        showStripeError('Connection error. Please check your internet and try again.');
      }
    }

    function showStripeError(msg) {
      const err = document.getElementById('stripe-error');
      const errMsg = document.getElementById('stripe-error-msg');
      if (err && errMsg) { errMsg.textContent = msg; err.classList.remove('hidden'); }
      const btn = document.getElementById('stripe-pay-btn');
      const loading = document.getElementById('stripe-loading');
      if (btn) btn.classList.remove('hidden');
      if (loading) loading.classList.add('hidden');
    }

    // ==================== STRIPE ====================
    // Replace with your LIVE publishable key when going live
    const STRIPE_PK = '<%= process.env.STRIPE_PUBLISHABLE_KEY %>';
    let stripeInstance = null;
    let cardNumber, cardExpiry, cardCvc;

    function loadStripeSDK() {
      return new Promise((resolve, reject) => {
        if (window.Stripe) { resolve(); return; }
        const s = document.createElement('script');
        s.src = 'https://js.stripe.com/v3/';
        s.onload = resolve;
        s.onerror = () => reject(new Error('Failed to load Stripe'));
        document.head.appendChild(s);
      });
    }

    async function initStripeElements() {
      try {
        await loadStripeSDK();
        stripeInstance = Stripe(STRIPE_PK);
        const elements = stripeInstance.elements({
          appearance: { theme: 'night' }
        });

        const style = {
          base: {
            color: '#FFFFFF',
            fontFamily: 'Inter, system-ui, sans-serif',
            fontSize: '16px',
            fontSmoothing: 'antialiased',
            '::placeholder': { color: '#8B949E' },
            iconColor: '#FF6A3D'
          },
          invalid: { color: '#F87171', iconColor: '#F87171' }
        };

        cardNumber = elements.create('cardNumber', { style, showIcon: true });
        cardExpiry = elements.create('cardExpiry', { style });
        cardCvc    = elements.create('cardCvc',    { style });

        cardNumber.mount('#stripe-card-number');
        cardExpiry.mount('#stripe-card-expiry');
        cardCvc.mount('#stripe-card-cvc');

        cardNumber.on('change', (e) => {
          if (e.error) showStripeError(e.error.message);
          else { const el = document.getElementById('stripe-error'); if (el) el.classList.add('hidden'); }
        });
      } catch(e) {
        console.error('Stripe init error:', e);
        showStripeError('Payment system unavailable. Please contact us at (502) 417-8040.');
      }
    }

    async function submitStripePayment() {
      if (!stripeInstance || !cardNumber) {
        showStripeError('Payment not initialized. Please refresh the page.');
        return;
      }
      const name = document.getElementById('stripe-name')?.value.trim();
      if (!name) { showStripeError('Please enter the cardholder name.'); return; }

      const btn     = document.getElementById('stripe-pay-btn');
      const loading = document.getElementById('stripe-loading');
      const errEl   = document.getElementById('stripe-error');

      if (btn) btn.classList.add('hidden');
      if (loading) loading.classList.remove('hidden');
      if (errEl) errEl.classList.add('hidden');

      try {
        // 1. Create PaymentIntent on server
        const amountCents = Math.round(formData.total * 100);
        const intentRes = await fetch('/api/create-payment-intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount: amountCents })
        });
        const intentData = await intentRes.json();
        if (!intentData.success) throw new Error(intentData.message || 'Failed to create payment');

        // 2. Confirm card payment with Stripe
        const { error, paymentIntent } = await stripeInstance.confirmCardPayment(intentData.clientSecret, {
          payment_method: {
            card: cardNumber,
            billing_details: {
              name: name,
              email: formData.contact.email || undefined,
              phone: formData.contact.phone || undefined
            }
          }
        });

        if (error) {
          showStripeError(error.message);
          return;
        }

        if (paymentIntent.status === 'succeeded') {
          // 3. Only NOW create the order
          await completeBooking(paymentIntent.id);
        } else {
          showStripeError('Payment not completed. Status: ' + paymentIntent.status);
        }
      } catch(e) {
        console.error('Payment error:', e);
        showStripeError(e.message || 'Payment failed. Please try again.');
      }
    }

    function nextStep() {
      if (validateCurrentStep()) {
        saveFormData();
        if (currentStep < 4) renderStep(currentStep + 1);
        // Step 4 handled by Stripe submit button
      }
    }

    function prevStep() {
      saveFormData();
      if (currentStep > 0) renderStep(currentStep - 1);
    }

    function goToStep(step) {
      if (step > currentStep && !validateCurrentStep()) return;
      renderStep(step);
    }

    // ==================== INIT ====================
    window.addEventListener('load', () => {
      renderStep(0);

      const script = document.createElement('script');
      script.src = "https://maps.googleapis.com/maps/api/js?key=AIzaSyADY34xlNO8-qSU_2Lq7qZ7l1jydiRL74w&libraries=places";
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    });
  </script>
</body>
</html>
