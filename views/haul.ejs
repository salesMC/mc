<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Haul with MC | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="hero-photo" style="background-image: url('/images/truck-highway.jpg');"></div>
    <div class="hero-dark-v"></div>
    <div class="hero-dark-h"></div>
    <div class="hero-tint"></div>
    <div class="glow-cyan" style="top: -140px; left: -100px;"></div>
    <div class="glow-orange" style="bottom: -120px; right: -80px;"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 pt-24 pb-28 md:pt-32 md:pb-36">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[rgba(34,211,238,0.3)] bg-[rgba(34,211,238,0.08)] text-xs font-medium text-[var(--cyan)] mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--cyan)]"></span>
          For Carriers
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.02] tracking-tight">
          <span class="text-dim">Haul with</span><br>
          <span class="text-white">MC.</span>
        </h1>

        <p class="mt-8 text-lg md:text-xl text-dim max-w-2xl leading-relaxed">
          Partner with a dispatch team that pays on time, finds consistent loads, and respects your business.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Become a Carrier</a>
          <a href="/payment-tracker" class="btn btn-cyan">Check Payment</a>
        </div>
      </div>
    </div>
  </section>

  <div class="horizon"></div>

  <!-- BENEFITS -->
  <section class="py-24 md:py-32 relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <div class="eyebrow text-[var(--cyan)] mb-5">Why Haul with MC</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-[1.1] tracking-tight">
          A dispatch partner <span class="text-dim">who understands the road.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="tile">
          <div class="w-12 h-12 mb-6 rounded-lg flex items-center justify-center text-[var(--orange)]" style="background: rgba(255,106,61,0.12); border: 1px solid rgba(255,106,61,0.3);">
            <i class="fas fa-dollar-sign"></i>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Fast Payment</h3>
          <p class="text-dim leading-relaxed text-[15px]">Quick-pay options so you're not waiting weeks on completed loads.</p>
        </div>
        <div class="tile">
          <div class="w-12 h-12 mb-6 rounded-lg flex items-center justify-center text-[var(--cyan)]" style="background: rgba(34,211,238,0.12); border: 1px solid rgba(34,211,238,0.3);">
            <i class="fas fa-route"></i>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Consistent Loads</h3>
          <p class="text-dim leading-relaxed text-[15px]">Nationwide network of dealers, auctions, and OEMs means steady freight in every direction.</p>
        </div>
        <div class="tile">
          <div class="w-12 h-12 mb-6 rounded-lg flex items-center justify-center text-[var(--purple)]" style="background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.3);">
            <i class="fas fa-headset"></i>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Real Dispatch Support</h3>
          <p class="text-dim leading-relaxed text-[15px]">Talk to real people who understand the road — not just a ticket queue.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="horizon"></div>

  <!-- CTA -->
  <section class="py-24 md:py-32 relative overflow-hidden bg-deep">
    <div class="glow-cyan" style="top: 10%; right: -100px;"></div>
    <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-[1.1] tracking-tight">
        Roll with a partner that values you.
      </h2>
      <p class="mt-6 text-lg text-dim leading-relaxed">
        Apply once — we'll get you onboarded fast.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="/contact" class="btn btn-primary">Start Application</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
