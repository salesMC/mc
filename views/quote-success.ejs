<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quote Received | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

  <%- include('partials/header') %>

  <main class="relative overflow-hidden min-h-[75vh] flex items-center">
    <div class="glow-lime" style="top: 10%; left: -100px;"></div>
    <div class="glow-cyan" style="bottom: 10%; right: -100px;"></div>

    <div class="relative max-w-xl mx-auto px-6 lg:px-8 text-center py-24">
      <div class="w-20 h-20 mx-auto mb-8 rounded-full flex items-center justify-center text-[var(--lime)]" style="background: rgba(190,242,100,0.12); border: 1px solid rgba(190,242,100,0.4);">
        <i class="fas fa-check text-3xl"></i>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight leading-[1.1]">
        Thanks — <span class="text-[var(--lime)]">we got it!</span>
      </h1>
      <p class="mt-6 text-lg text-dim leading-relaxed">
        Your quote request has been received. A member of our team will reach out shortly to confirm your exact price and pickup window.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/contact" class="btn btn-ghost">Ask a Question</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
