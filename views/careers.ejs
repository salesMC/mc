<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Careers | MC Transportation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

  <%- include('partials/header') %>

  <!-- HERO -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="glow-cyan" style="top: -140px; right: -100px;"></div>
    <div class="glow-orange" style="bottom: -120px; left: -80px;"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[rgba(34,211,238,0.3)] bg-[rgba(34,211,238,0.08)] text-xs font-medium text-[var(--cyan)] mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--cyan)]"></span>
          Join Our Team
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.02] tracking-tight">
          <span class="text-dim">Careers at</span><br>
          <span class="text-white">MC <span class="text-[var(--cyan)]">Transportation.</span></span>
        </h1>

        <p class="mt-8 text-lg md:text-xl text-dim max-w-2xl leading-relaxed">
          Join a team that moves the automotive industry forward. We're building the future of vehicle logistics — reliable, fast, and nationwide.
        </p>
      </div>
    </div>
  </section>

  <div class="horizon"></div>

  <!-- OPENINGS -->
  <section class="py-24 md:py-32 relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <div class="eyebrow text-[var(--orange)] mb-5">Open Roles</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-[1.1] tracking-tight">
          Find your role <span class="text-dim">and help us deliver excellence on every mile.</span>
        </h2>
      </div>

      <div class="space-y-4">
        <div class="tile flex flex-col md:flex-row md:items-center md:justify-between gap-6 p-6 md:p-8">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs font-semibold tracking-widest uppercase text-[var(--orange)] bg-[rgba(255,106,61,0.1)] border border-[rgba(255,106,61,0.25)] px-2 py-0.5 rounded">Sales</span>
              <span class="text-xs text-muted">Atlanta, GA</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">Sales Enablement</h3>
            <p class="text-dim text-sm mt-1">Drive sales productivity with training, tooling, and process.</p>
          </div>
          <a href="#" class="btn btn-ghost flex-shrink-0">
            More Details
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/></svg>
          </a>
        </div>

        <div class="tile flex flex-col md:flex-row md:items-center md:justify-between gap-6 p-6 md:p-8">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs font-semibold tracking-widest uppercase text-[var(--cyan)] bg-[rgba(34,211,238,0.1)] border border-[rgba(34,211,238,0.25)] px-2 py-0.5 rounded">Operations</span>
              <span class="text-xs text-muted">Louisville, KY</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">Dispatcher</h3>
            <p class="text-dim text-sm mt-1">Coordinate carriers, routes, and customers in real time.</p>
          </div>
          <a href="#" class="btn btn-ghost flex-shrink-0">
            More Details
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/></svg>
          </a>
        </div>

        <div class="tile flex flex-col md:flex-row md:items-center md:justify-between gap-6 p-6 md:p-8">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs font-semibold tracking-widest uppercase text-[var(--purple)] bg-[rgba(167,139,250,0.1)] border border-[rgba(167,139,250,0.25)] px-2 py-0.5 rounded">Driver</span>
              <span class="text-xs text-muted">Nationwide</span>
            </div>
            <h3 class="text-2xl font-semibold text-white">Car Hauler CDL Driver</h3>
            <p class="text-dim text-sm mt-1">OTR car hauler with consistent lanes and fast-pay options.</p>
          </div>
          <a href="#" class="btn btn-ghost flex-shrink-0">
            More Details
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/></svg>
          </a>
        </div>
      </div>

      <div class="text-center mt-12">
        <p class="text-muted text-sm">Don't see your role? Reach out — we're always hiring great people.</p>
        <a href="/contact" class="btn btn-primary mt-6 inline-flex">Send Us Your Resume</a>
      </div>

    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
